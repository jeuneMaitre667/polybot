# Clé privée du wallet Polygon (sans 0x si besoin, le script l'ajoute)
# À utiliser UNIQUEMENT un wallet dédié au bot, avec peu de fonds
PRIVATE_KEY=your_hex_private_key_here

# RPC Polygon (optionnel, défaut: https://polygon-rpc.com)
# POLYGON_RPC_URL=https://polygon-rpc.com

# Montant par ordre en USDC si USE_BALANCE_AS_SIZE=false (défaut: 10)
ORDER_SIZE_USD=10

# Taille = solde USDC du wallet pour réinvestir les gains (true/false). Défaut: true.
# Si true, chaque ordre utilise tout le solde USDC disponible (résultat des trades précédents).
# USE_BALANCE_AS_SIZE=true

# Montant minimum pour placer un ordre en USDC (défaut: 1). En dessous, le bot skip.
# ORDER_SIZE_MIN_USD=1

# Ordre au marché (true) ou limite (false). Défaut: false = ordre limite (règle du bot)
# USE_MARKET_ORDER=false

# Intervalle de surveillance en secondes (défaut: 5)
POLL_INTERVAL_SEC=5

# Placer les ordres en auto (true/false). Défaut: true. Mettre false pour faire tourner le bot sans trader.
# AUTO_PLACE_ENABLED=true

# URL du repo Git pour redéploiement depuis Lightsail (optionnel). Exemple :
# GIT_REPO_URL=https://github.com/VOTRE_USER/polymarket-dashboard.git
