# =============================================================================
# Go / no-go avant pm2 start (résumé)
# =============================================================================
# [ ] MARKET_MODE=15m (ou hourly) — ci-dessous : exemple 15m
# [ ] PRIVATE_KEY = clé 64 hex (wallet dédié), JAMAIS dans Git (.env ignoré)
# [ ] et15mEntryTiming.js présent à côté de index.js (grille ET 15m = dashboard)
# [ ] POLYGON_RPC_URL fiable recommandé (+ optionnel POLYGON_RPC_FALLBACK)
# [ ] ORDER_SIZE_USD / USE_BALANCE_AS_SIZE / MAX_STAKE_USD = cohérents avec le risque
# [ ] AUTO_PLACE_ENABLED=true UNIQUEMENT quand tu es prêt à trader en réel
# =============================================================================

# Marché : hourly = bitcoin-up-or-down (1 h), 15m = btc-updown-15m (15 min). Défaut code : hourly.
# Deuxième serveur : MARKET_MODE=15m + autre PRIVATE_KEY pour isoler le risque.
MARKET_MODE=15m

# CLÉ PRIVÉE du wallet Polygon (64 hex, avec ou sans 0x) — PAS l'adresse (40 hex).
# Phantom/MetaMask → Sécurité → Exporter la clé privée. Wallet dédié, peu de fonds.
PRIVATE_KEY=your_hex_private_key_here

# RPC Polygon — défaut code si absent : https://polygon-bor-rpc.publicnode.com
# En prod : Alchemy (recommandé), Infura, QuickNode, etc.
#
# --- Guide Alchemy (Polygon Mainnet) ---
# 1) Va sur https://www.alchemy.com/ → créer un compte / te connecter.
# 2) Dashboard → « Create new app » (ou « + App »).
#    - Chain : Polygon
#    - Network : Polygon Mainnet  (pas Mumbai/Amoy sauf test)
# 3) Ouvre l’app → onglet « API Key » ou « HTTPS » → copie l’URL du type :
#    https://polygon-mainnet.g.alchemy.com/v2/xxxxxxxx
# 4) Colle-la ci-dessous dans POLYGON_RPC_URL (une seule ligne, sans guillemets).
# 5) Garde un fallback public (publicnode) pour secours si Alchemy est en panne :
#    POLYGON_RPC_FALLBACK=https://polygon-bor-rpc.publicnode.com,https://polygon-rpc.com
# 6) Sur le VPS : nano ~/bot-24-7/.env → même lignes → pm2 restart polymarket-bot
# Ne commite jamais la vraie URL (la clé est dans l’URL).
#
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/VOTRE_CLE_ALCHEMY
#
# Secours si le RPC principal échoue (liste séparée par des virgules).
# Défaut code : polygon-rpc.com + publicnode (Ankr public exige souvent une clé API — sinon erreurs redeem / nonce).
# POLYGON_RPC_FALLBACK=https://polygon-bor-rpc.publicnode.com,https://polygon-rpc.com

# --- CLOB (credentials dérivés automatiquement depuis PRIVATE_KEY ; pas de clés API à coller) ---
# Erreur 400 "Could not create api key" : souvent « clé API déjà créée » pour ce wallet — le bot refait alors deriveApiKey.
# Ordre code : derive → create si derive incomplet → si create renvoie 400, derive à nouveau (pas de boucle create).
# Si ça bloque encore : CLOB_SIGNATURE_TYPE / compte Polymarket / PRIVATE_KEY.
# Compte Polymarket (email / Magic) : CLOB_SIGNATURE_TYPE=1 + CLOB_FUNDER_ADDRESS = adresse « Profil » sur polymarket.com
# (celle affichée dans Paramètres, souvent ≠ l’adresse EOA dérivée de PRIVATE_KEY). Sinon le bot trade un autre compte.
# Compte wallet-only EOA : CLOB_SIGNATURE_TYPE=0 (pas de CLOB_FUNDER_ADDRESS, ou = même adresse que le signer).
# Safe Gnosis : souvent CLOB_SIGNATURE_TYPE=2 + CLOB_FUNDER_ADDRESS = adresse du Safe / profil.
# CLOB_SIGNATURE_TYPE=1
# CLOB_FUNDER_ADDRESS=0x... # copier-coller depuis Profil Polymarket (même casse OK)

# Montant par ordre en USDC si USE_BALANCE_AS_SIZE=false (défaut code : 10)
ORDER_SIZE_USD=10

# Plafond fixe par ordre (USDC). Vide ou absent = désactivé (pas de plafond MAX_STAKE).
# MAX_STAKE_USD=5000

# Legacy « mise max » carnet (désactivé par défaut — avec FAK + MARKET_WORST_PRICE_P, inutile en général) :
# USE_LIQUIDITY_CAP=true
# RECORD_LIQUIDITY_HISTORY=true
# Throttle log JSON/console « fetchActiveWindows: créneaux actifs » (évite bot.log énorme). Défaut 120000 ms ; 0 = chaque cycle.
# LOG_FETCH_ACTIVE_WINDOWS_MS=120000
# Si bot.log ne grossit plus : regarder stderr PM2 « [bot.log] Écriture impossible » (permissions, disque) ; chown ubuntu bot.log

# Taille = tout le solde USDC (défaut code : true sauf USE_BALANCE_AS_SIZE=false).
# USE_BALANCE_AS_SIZE=true

# Budget “réinvestissement uniquement des gains” :
# - reserve_excess_from_start : le bot fige la “réserve” = (solde au démarrage - BOT_START_STAKE_USD)
#   et ne l’utilise jamais pour placer des trades.
# - Ensuite il réinvestit uniquement ce qui vient du dépassement (ex: 15$ au départ, BOT_START_STAKE_USD=10 =>
#   réserve 5$, trades démarrent à ~10$ puis grossissent avec les gains/pertes).
# BOT_BUDGET_MODE=reserve_excess_from_start
# BOT_START_STAKE_USD=10
# BOT_RESERVED_EXTRA_USD=5   # optionnel : fixer la réserve à la main (sinon calculé depuis le solde au 1er démarrage)

# Montant minimum pour placer un ordre (défaut : 1 USDC).
# ORDER_SIZE_MIN_USD=1

# Ordre au marché (true) = exécution immédiate. Limite (false) = ordre limite.
USE_MARKET_ORDER=true

# Pire prix accepté pour un BUY marché (défaut code : 0.98 si non défini).
MARKET_WORST_PRICE_P=0.98

# FAK = partiel OK ; FOK = tout ou rien.
MARKET_ORDER_TIF=FAK

# Si FAK partiel : compléments sur le reliquat (défaut : activé sauf PARTIAL_FILL_RETRY=false).
# PARTIAL_FILL_RETRY_MAX_EXTRA=5
# PARTIAL_FILL_RETRY_DELAY_MS=400
# PARTIAL_FILL_RETRY_MAX_WINDOW_MS=15000
# PARTIAL_FILL_RETRY_MIN_REMAINING_USD=0.5
# PARTIAL_FILL_RETRY_REVALIDATE_PRICE=false

# Garde « gain si victoire » (défaut : activé sauf REQUIRE_WIN_GROSS_GAIN_GUARD=false).
# MIN_WIN_GROSS_PROFIT_USD=0

# Fenêtre signal (défaut code : 0.97 – 0.98).
# MIN_SIGNAL_P=0.97
# MAX_SIGNAL_P=0.98
# MAX_PRICE_LIQUIDITY=0.98
# Ordre marché : marge au-dessus du best ask (défaut 0.99 si absent).
# MARKET_WORST_PRICE_P=0.99

# Source prix poll : gamma | clob. Défaut code : clob si MARKET_MODE=15m, sinon gamma.
# SIGNAL_PRICE_SOURCE=clob
# BEST_ASK_SIGNAL_CACHE_MS=400
#
# Observabilité : logger les prix Up/Down vus par fetchSignals même hors [MIN_SIGNAL_P, MAX_SIGNAL_P] (pas d’ordre en plus).
# JSON `signal_visibility_poll` dans bot.log + une ligne console ; throttle pour limiter le volume.
# SIGNAL_VISIBILITY_LOG=true
# SIGNAL_VISIBILITY_LOG_MS=10000

# Sizing avg (activé seulement si USE_AVG_PRICE_SIZING=true dans l’environnement).
USE_AVG_PRICE_SIZING=true
AVG_PRICE_TOL_P=0.0005
AVG_PRICE_BIN_ITERS=25

# Abonnement WebSocket CLOB pour déclenchement rapide (défaut code : activé sauf USE_WEBSOCKET=false).
# USE_WEBSOCKET=true

# Tenter redeem des positions gagnantes → USDC en début de cycle (défaut code : activé sauf REDEEM_ENABLED=false).
# REDEEM_ENABLED=true
# Throttle du log « Redeem relayer sans succès » par conditionId (ms). Défaut 600000 = 10 min.
# REDEEM_NO_SUCCESS_LOG_MS=600000
# Après un échec redeem, réessai pour ce marché au plus tôt après N ms (défaut 120000 = 2 min — utile la nuit si l’oracle CTF est en retard).
# REDEEM_FAIL_BACKOFF_MS=120000
# Après la fin du marché (Gamma, champ stocké au trade comme marketEndMs), attendre N ms avant le 1er redeem pour ce conditionId.
# Défaut code si absent : 60000 en MARKET_MODE=15m, 0 en hourly. 0 = désactiver ce garde-fou.
# REDEEM_AFTER_MARKET_END_MS=60000
# Sans marketEndMs/endDate dans orders.log / last-order : par défaut le bot ne tente pas le redeem (évite Telegram « échec » avant fin de créneau).
# REDEEM_ALLOW_UNKNOWN_MARKET_END_MS=true   # ancien comportement : tenter quand même
# Skip permanent (liste de conditionId séparés par des virgules), ex. si tu as claim manuellement : REDEEM_SKIP_CONDITION_IDS=0x...
#
# Redeem via relayer Polymarket (si CLOB_SIGNATURE_TYPE=1 proxy Magic ou 2 Safe) : même PRIVATE_KEY signe,
# la tx est relayée (gasless). Doc Polymarket « Submit a transaction ».
#
# Recommandé : clés « API du Relayer » uniquement (ne pas remplir POLY_BUILDER_* si tu ne les utilises pas) :
# RELAYER_API_KEY=
# RELAYER_API_KEY_ADDRESS=0x...   # = signataire = adresse dérivée de PRIVATE_KEY (pas l’adresse proxy affichée sur le profil)
#
# Alternative si tu n’as pas de clés Relayer : Builder HMAC (programme Builder) :
# POLY_BUILDER_API_KEY=
# POLY_BUILDER_SECRET=
# POLY_BUILDER_PASSPHRASE=
#
# Si Relayer + Builder sont tous les deux remplis : le redeem utilise les clés Relayer (évite 401 si Builder est faux/expiré).
#
# 401 avec Builder seul : vérifier package.json — @polymarket/builder-signing-sdk en 0.0.8 avec builder-relayer-client 0.0.8.
#
# Relayer API ou Builder + type CLOB 1 ou 2 → relayer redeem par défaut (auto).
# REDEEM_VIA_RELAYER=false   # forcer uniquement redeem EOA (gas POL)
# REDEEM_VIA_RELAYER=true    # forcer relayer (sinon creds/type invalides → log + fallback EOA)
# POLY_RELAYER_URL=https://relayer-v2.polymarket.com

# Cache carnet CLOB (ms). Défaut code : 3000 si 15m, 1500 si hourly.
# BOOK_CACHE_MS=3000

# RECORD_MISE_MAX_ON_SIGNAL_ONLY=true
# INCLUDE_ACTIVE_WINDOW_LIQUIDITY=false
# WS_DEBOUNCE_MS=300
# Throttle des logs [signal_in_range_but_no_order] (ms). Défaut 5000.
# SIGNAL_IN_RANGE_NO_ORDER_LOG_MS=5000
# USE_WS_PRICE_ONLY=true
# POLL_INTERVAL_SEC=1
# CYCLE_PROFILER=1

# =============================================================================
# Autotrade : false par défaut — aucun ordre envoyé tant que ce n’est pas true.
# =============================================================================
AUTO_PLACE_ENABLED=false

# URL du repo Git pour redeploy.sh (Lightsail). Optionnel pour un run local simple.
GIT_REPO_URL=https://github.com/jeuneMaitre667/polybot.git

# status-server.js
# BOT_STATUS_PORT=3001
# BOT_STATUS_SECRET=un_secret_pour_proteger_l_api
# Après reconnexion WS : alerte si aucun événement best_bid_ask (secondes). Défaut 45.
# WS_NO_BOOK_ALERT_AFTER_SEC=45

# Alertes (check-bot-health.sh + cron)
# ALERT_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# ALERT_TELEGRAM_BOT_TOKEN=...
# ALERT_TELEGRAM_CHAT_ID=...
#
# Alertes temps réel depuis le bot (index.js) — même token + chat_id que ci-dessus
# Trade exécuté : position, remplissage, PnL latente (vs best bid), solde CLOB après trade, Δ solde depuis démarrage process.
# Redeem : succès (tx) ou échec / relayer sans MINED (même throttle que les logs console pour les échecs relayer).
# ALERT_TELEGRAM_TRADE=false          # désactiver seulement les alertes trade (défaut : activé si token+chat)
# ALERT_TELEGRAM_REDEEM=false         # désactiver seulement redeem
# ALERT_TELEGRAM_STOPLOSS=false      # désactiver seulement les alertes stop-loss dédiées (défaut : activé si token+chat)
# ALERT_TELEGRAM_BALANCE_EVERY_MS=0   # >0 = message périodique « solde cycle » (ex. 3600000 = 1 h), seulement quand le cycle poll atteint le bloc solde (AUTO_PLACE on)

# Autres (défauts dans index.js si non définis)
# GAMMA_EVENTS_CACHE_MS=4000
# CREDS_CACHE_TTL_MS=21600000
# PRE_SIGN_CACHE_TTL_MS=60000
# ENABLE_HEARTBEAT=false
# BOT_LOG_MAX_MB=50
# BOT_LOG_ROTATE_KEEP=5
