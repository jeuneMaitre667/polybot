# Marché : hourly = créneaux 1 h (bitcoin-up-or-down), 15m = créneaux 15 min (btc-updown-15m). Défaut: hourly.
# Sur un second serveur, mets MARKET_MODE=15m et un autre wallet (PRIVATE_KEY) pour isoler le risque.
# MARKET_MODE=hourly

# CLÉ PRIVÉE du wallet Polygon (64 caractères hex, avec ou sans 0x) — PAS l'adresse du wallet (40 caractères).
# À récupérer : Phantom/MetaMask → Paramètres → Sécurité → Exporter clé privée.
# À utiliser UNIQUEMENT un wallet dédié au bot, avec peu de fonds.
PRIVATE_KEY=your_hex_private_key_here

# RPC Polygon (optionnel, défaut: https://polygon-rpc.com)
# POLYGON_RPC_URL=https://polygon-rpc.com

# Montant par ordre en USDC si USE_BALANCE_AS_SIZE=false (défaut: 10)
ORDER_SIZE_USD=10

# Taille = solde USDC du wallet pour réinvestir les gains (true/false). Défaut: true.
# Si true, chaque ordre utilise tout le solde USDC disponible (résultat des trades précédents).
# USE_BALANCE_AS_SIZE=true

# Montant minimum pour placer un ordre en USDC (défaut: 1). En dessous, le bot skip.
# ORDER_SIZE_MIN_USD=1

# Ordre au marché (true) = exécution immédiate, recommandé pour latence min. Limite (false) = prix fixe 96,8–97 %.
USE_MARKET_ORDER=true

# Fenêtre de prix pour signaux et mise max (optionnel). Défaut: 97 % – 97,5 %.
# MIN_SIGNAL_P=0.97
# MAX_SIGNAL_P=0.975
# MAX_PRICE_LIQUIDITY=0.975

# Sizing “avg constrained” (recommandé pour garder un avg price proche du bestAsk live):
# - le bot calcule la taille max (USDC) telle que le prix moyen de remplissage reste <= bestAsk_live + tol
# - et garde worstPrice = MAX_P (donc pas de remplissage au-dessus de 97,5c)
USE_AVG_PRICE_SIZING=true
# Tolérance en delta de prix (ex: 0.0005 = 0,05c)
AVG_PRICE_TOL_P=0.0005
# Itérations de binary search (plus haut = plus précis, un peu plus CPU)
AVG_PRICE_BIN_ITERS=25

# Mise max : true (défaut) = enregistrer 1 seule fois au moment du signal détecté/évalué.
# false = mode legacy (relevés périodiques en créneau actif).
# RECORD_MISE_MAX_ON_SIGNAL_ONLY=true

# Dashboard/status-server: inclure les anciennes entrées source=active_window dans les stats (false recommandé).
# INCLUDE_ACTIVE_WINDOW_LIQUIDITY=false

# Debounce WebSocket en ms avant de tenter un ordre (évite rafales). Défaut: 300.
# WS_DEBOUNCE_MS=300

# Utiliser uniquement le prix WS (pas de re-validation REST getBestAsk) avant de placer → ~50–150 ms de gagné. Défaut: true. Mettre false pour re-valider le prix par REST.
# USE_WS_PRICE_ONLY=true

# Intervalle de surveillance en secondes (défaut: 1)
POLL_INTERVAL_SEC=1

# Afficher en console le détail des temps par étape du cycle (pour voir où le temps est perdu). Défaut: false.
# CYCLE_PROFILER=1

# Placer les ordres en auto (true/false). Défaut: true. Mettre false pour faire tourner le bot sans trader.
# AUTO_PLACE_ENABLED=true

# URL du repo Git pour redéploiement depuis Lightsail (obligatoire pour redeploy.sh).
GIT_REPO_URL=https://github.com/jeuneMaitre667/polybot.git

# Serveur de statut (optionnel) — port et token pour status-server.js
# BOT_STATUS_PORT=3001
# BOT_STATUS_SECRET=un_secret_pour_proteger_l_api

# Alerte si le bot plante (check-bot-health.sh + cron). Un seul des deux suffit.
# ALERT_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# ALERT_TELEGRAM_BOT_TOKEN=...
# ALERT_TELEGRAM_CHAT_ID=...
