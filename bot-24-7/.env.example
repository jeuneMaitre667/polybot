# =============================================================================
# Go / no-go avant pm2 start (résumé)
# =============================================================================
# [ ] MARKET_MODE=15m (ou hourly) — ci-dessous : exemple 15m
# [ ] PRIVATE_KEY = clé 64 hex (wallet dédié), JAMAIS dans Git (.env ignoré)
# [ ] et15mEntryTiming.js présent à côté de index.js (grille ET 15m = dashboard)
# [ ] POLYGON_RPC_URL fiable recommandé (+ optionnel POLYGON_RPC_FALLBACK)
# [ ] ORDER_SIZE_USD / USE_BALANCE_AS_SIZE / MAX_STAKE_USD = cohérents avec le risque
# [ ] AUTO_PLACE_ENABLED=true UNIQUEMENT quand tu es prêt à trader en réel
# =============================================================================

# Marché : hourly = bitcoin-up-or-down (1 h), 15m = btc-updown-15m (15 min). Défaut code : hourly.
# Deuxième serveur : MARKET_MODE=15m + autre PRIVATE_KEY pour isoler le risque.
MARKET_MODE=15m

# CLÉ PRIVÉE du wallet Polygon (64 hex, avec ou sans 0x) — PAS l'adresse (40 hex).
# Phantom/MetaMask → Sécurité → Exporter la clé privée. Wallet dédié, peu de fonds.
PRIVATE_KEY=your_hex_private_key_here

# RPC Polygon — défaut code si absent : https://polygon-bor-rpc.publicnode.com
# En prod : Alchemy, Infura, QuickNode, etc.
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/VOTRE_CLE
#
# Secours si le RPC principal échoue (liste séparée par des virgules). Défaut code si absent :
# https://polygon-rpc.com,https://rpc.ankr.com/polygon
# POLYGON_RPC_FALLBACK=https://polygon-rpc.com,https://rpc.ankr.com/polygon

# --- CLOB (credentials dérivés automatiquement depuis PRIVATE_KEY ; pas de clés API à coller) ---
# Si erreurs de signature / compte Polymarket : essayer CLOB_SIGNATURE_TYPE=2 (voir commentaires dans index.js).
# CLOB_SIGNATURE_TYPE=0
# Adresse du compte qui détient les USDC sur Polymarket si différente du signer (cas avancé).
# CLOB_FUNDER_ADDRESS=0x...

# Montant par ordre en USDC si USE_BALANCE_AS_SIZE=false (défaut code : 10)
ORDER_SIZE_USD=10

# Plafond fixe par ordre (USDC). Vide ou absent = désactivé (pas de plafond MAX_STAKE).
# MAX_STAKE_USD=5000

# Legacy « mise max » carnet (désactivé par défaut — avec FAK + MARKET_WORST_PRICE_P, inutile en général) :
# USE_LIQUIDITY_CAP=true
# RECORD_LIQUIDITY_HISTORY=true

# Taille = tout le solde USDC (défaut code : true sauf USE_BALANCE_AS_SIZE=false).
# USE_BALANCE_AS_SIZE=true

# Montant minimum pour placer un ordre (défaut : 1 USDC).
# ORDER_SIZE_MIN_USD=1

# Ordre au marché (true) = exécution immédiate. Limite (false) = ordre limite.
USE_MARKET_ORDER=true

# Pire prix accepté pour un BUY marché (défaut code : 0.98 si non défini).
MARKET_WORST_PRICE_P=0.98

# FAK = partiel OK ; FOK = tout ou rien.
MARKET_ORDER_TIF=FAK

# Si FAK partiel : compléments sur le reliquat (défaut : activé sauf PARTIAL_FILL_RETRY=false).
# PARTIAL_FILL_RETRY_MAX_EXTRA=5
# PARTIAL_FILL_RETRY_DELAY_MS=400
# PARTIAL_FILL_RETRY_MAX_WINDOW_MS=15000
# PARTIAL_FILL_RETRY_MIN_REMAINING_USD=0.5
# PARTIAL_FILL_RETRY_REVALIDATE_PRICE=false

# Garde « gain si victoire » (défaut : activé sauf REQUIRE_WIN_GROSS_GAIN_GUARD=false).
# MIN_WIN_GROSS_PROFIT_USD=0

# Fenêtre signal (défaut : 0.97 – 0.975).
# MIN_SIGNAL_P=0.97
# MAX_SIGNAL_P=0.975
# MAX_PRICE_LIQUIDITY=0.975

# Source prix poll : gamma | clob. Défaut code : clob si MARKET_MODE=15m, sinon gamma.
# SIGNAL_PRICE_SOURCE=clob
# BEST_ASK_SIGNAL_CACHE_MS=400

# Sizing avg (activé seulement si USE_AVG_PRICE_SIZING=true dans l’environnement).
USE_AVG_PRICE_SIZING=true
AVG_PRICE_TOL_P=0.0005
AVG_PRICE_BIN_ITERS=25

# Abonnement WebSocket CLOB pour déclenchement rapide (défaut code : activé sauf USE_WEBSOCKET=false).
# USE_WEBSOCKET=true

# Tenter redeem des positions gagnantes → USDC en début de cycle (défaut code : activé sauf REDEEM_ENABLED=false).
# REDEEM_ENABLED=true

# Cache carnet CLOB (ms). Défaut code : 3000 si 15m, 1500 si hourly.
# BOOK_CACHE_MS=3000

# RECORD_MISE_MAX_ON_SIGNAL_ONLY=true
# INCLUDE_ACTIVE_WINDOW_LIQUIDITY=false
# WS_DEBOUNCE_MS=300
# Throttle des logs [signal_in_range_but_no_order] (ms). Défaut 5000.
# SIGNAL_IN_RANGE_NO_ORDER_LOG_MS=5000
# USE_WS_PRICE_ONLY=true
# POLL_INTERVAL_SEC=1
# CYCLE_PROFILER=1

# =============================================================================
# Autotrade : false par défaut — aucun ordre envoyé tant que ce n’est pas true.
# =============================================================================
AUTO_PLACE_ENABLED=false

# URL du repo Git pour redeploy.sh (Lightsail). Optionnel pour un run local simple.
GIT_REPO_URL=https://github.com/jeuneMaitre667/polybot.git

# status-server.js
# BOT_STATUS_PORT=3001
# BOT_STATUS_SECRET=un_secret_pour_proteger_l_api

# Alertes (check-bot-health.sh + cron)
# ALERT_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# ALERT_TELEGRAM_BOT_TOKEN=...
# ALERT_TELEGRAM_CHAT_ID=...

# Autres (défauts dans index.js si non définis)
# GAMMA_EVENTS_CACHE_MS=4000
# CREDS_CACHE_TTL_MS=21600000
# PRE_SIGN_CACHE_TTL_MS=60000
# ENABLE_HEARTBEAT=false
# BOT_LOG_MAX_MB=50
# BOT_LOG_ROTATE_KEEP=5
