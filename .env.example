# Bot 15m (recommandé si tu n’as qu’un status-server) — ex. http://IP_LIGHTSAIL:3001
# VITE_BOT_STATUS_URL_15M=http://TON_IP:3001

# Bot horaire (optionnel). Laisser vide ou commenté si tu n’as plus que le 15m ; les cartes « 1h » restent en placeholder.
# VITE_BOT_STATUS_URL=http://TON_IP:3001

# Adresse Polymarket (Profil / proxy) pour l’historique des trades (Data API). Prioritaire sur le wallet connecté.
# Si absent : on utilise clobFunderAddress du last-order bot (15m puis horaire), puis le wallet connecté.
# VITE_TRADE_HISTORY_ADDRESS=0xVotreAdresseProfilPolymarket

# Bande signal live + liquidité (défaut code : 0.77–0.78 si absent). Aligné MIN_SIGNAL_P / MAX_SIGNAL_P du bot.
# VITE_ORDER_BOOK_SIGNAL_MIN_P=0.77
# VITE_ORDER_BOOK_SIGNAL_MAX_P=0.78

# --- Référence backtest 15m (live + SL cohérents) : copier ces lignes dans `.env` puis redémarrer Vite ---
# VITE_BACKTEST_15M_LIVE_ONLY=true
# VITE_BACKTEST_SL_BID_PROXY_FROM_MID=false
# Durée min. (s) où le prix reste ≥ seuil détection — aligné bot (POLL_INTERVAL_SEC=1 → 1). 0 = tout franchissement compte (plus de signaux qu’en live).
# VITE_BACKTEST_SIGNAL_MIN_DWELL_SEC=1

# Backtest 15m — PnL : perte fixe par SL en fraction du stake (défaut 0,25). Le seuil SL (¢) reste celui du bot pour la détection.
# VITE_BACKTEST_SL_FIXED_LOSS_FRAC=0.25

# Backtest 15m — aligner sur STOP_LOSS_TRIGGER_PRICE_P du bot (ex. 60¢).
# VITE_BACKTEST_STOP_LOSS_TRIGGER_PRICE_P=0.60
# VITE_BACKTEST_STOP_LOSS_DRAWDOWN_ENABLED=false
# VITE_BACKTEST_STOP_LOSS_MAX_DRAWDOWN_PCT=30
# VITE_BACKTEST_STOP_LOSS_MIN_HOLD_MS=10000

# Script `npm run recalc:day-16h` : fenêtre horaire ET (défaut 0 ≤ h < 17 = jusqu’à 16h59) ; perte SL fixe défaut 25 % (`SL_FIXED_LOSS_FRAC`).
# RECALC_HOUR_END_EXCLUSIVE=17
# SL_FIXED_LOSS_FRAC=0.25

# Backtest 15m — forcer « Stop-loss » sur des créneaux (SL live déclenché mais vente FAK refusée) :
# fins de créneau UTC en secondes et/ou conditionId, séparés par des virgules. Défaut code : 28 mars 10:15 / 10:30 ET (2024 et 2026).
# VITE_BACKTEST_MANUAL_SL_SLOT_END_SECS=
# VITE_BACKTEST_MANUAL_SL_CONDITION_IDS=

# Backtest 15m — ignorer le JSON statique même si VITE_BACKTEST_15M_STATIC_JSON est défini (toujours recalcul API live, SL à jour).
# VITE_BACKTEST_15M_LIVE_ONLY=true

# Backtest 15m — désactiver toute détection de stop-loss simulé (colonne Simul. sans « Stop-loss »). Défaut : activé si absent.
# VITE_BACKTEST_STOP_LOSS_ENABLED=false

# Backtest 15m — SL : par défaut le prix testé est un proxy « bid » = mid CLOB − offset (~0,007). Si tu n’as aucun SL simulé alors que le marché bouge :
# VITE_BACKTEST_SL_BID_PROXY_FROM_MID=false
# …utilise le mid brut (plus de franchissements du seuil). Ou augmente l’écart mid→bid (ex. 0,02) :
# VITE_BACKTEST_SL_BID_FROM_MID_OFFSET_P=0.02

# Backtest 15m — charger un JSON pré-généré (pas d’appels API live). Après `npm run cache:15m`, ex. :
# VITE_BACKTEST_15M_STATIC_JSON=/data/btc-15m-cache.json
#
# Génération du cache avec bande + SL (ex. 77–78¢, SL 60¢) — variables pour le script `npm run cache:15m` uniquement :
# BACKTEST_WINDOW_HOURS=720
# BACKTEST_SIGNAL_MIN_C=77
# BACKTEST_SIGNAL_MAX_C=78
# BACKTEST_SL_C=60
# SL_FIXED_LOSS_FRAC=0.25
