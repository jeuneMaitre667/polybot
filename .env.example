# URL du serveur de statut du bot (Lightsail). Ex. http://18.201.105.68:3001
# VITE_BOT_STATUS_URL=http://TON_IP_LIGHTSAIL:3001

# URL du serveur de statut du bot 15m (optionnel). Affiche la carte "Mise max 15m (moy. 3 j)".
# VITE_BOT_STATUS_URL_15M=http://18.203.159.101:3001

# Adresse Polymarket (Profil / proxy) pour l’historique des trades (Data API). Prioritaire sur le wallet connecté.
# Si absent : on utilise clobFunderAddress du last-order bot (15m puis horaire), puis le wallet connecté.
# VITE_TRADE_HISTORY_ADDRESS=0xVotreAdresseProfilPolymarket

# Backtest 15m (carte « résultats passés ») — aligner sur le bot (bot-24-7/.env) pour que le SL simulé colle au live.
# Défauts dans le code = mêmes ordres de grandeur que index.js ; sans ces lignes, le seuil SL affiché peut être 0.75 alors que le serveur est à 0.70.
# VITE_BACKTEST_STOP_LOSS_TRIGGER_PRICE_P=0.70
# VITE_BACKTEST_STOP_LOSS_MAX_DRAWDOWN_PCT=30
# VITE_BACKTEST_STOP_LOSS_MIN_HOLD_MS=10000
